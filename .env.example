# ─── Required ─────────────────────────────────────────────────────────────────

# Port the server listens on (Render sets this automatically)
PORT=3000

# Firebase Admin SDK service account — paste the full JSON as a single-line string.
# Get it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Either env var name is accepted:
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"vee-chat-36720",...}
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}   ← alternative name

# ─── Optional ─────────────────────────────────────────────────────────────────

# Firebase Realtime Database URL.
# Defaults to: https://vee-chat-36720-default-rtdb.asia-southeast1.firebasedatabase.app
# FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com

# Log level: trace | debug | info | warn | error | fatal  (default: info)
# LOG_LEVEL=info

# ─── Already set on Render (all routes that use these are server-side only) ───

# OneSignal — used by POST /api/notifications/send
# ONESIGNAL_APP_ID=7bcaa8e5-f51a-4b57-ab3a-7600ea06709c
# ONESIGNAL_REST_API_KEY=...

# Cloudinary — used by POST /api/cloudinary/delete
# CLOUDINARY_CLOUD_NAME=db6yriudg
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
